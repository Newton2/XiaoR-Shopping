{
  "name": "xiaor-shopping",
  "version": "1.0.0",
  "description": "XiaoR-Shopping - Save Money on Every Purchase",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac"
  },
  "build": {
    "appId": "org.xiaor.shopping",
    "productName": "XiaoR-Shopping",
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  }
}